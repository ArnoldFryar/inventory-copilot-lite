# OpsCopilot-Lite — example environment variables
#
# Copy this file to .env and fill in real values.
# .env is gitignored and must NEVER be committed.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── Plan (override — forces plan for all users, bypasses Stripe) ──────────────
# Set to "pro" to unlock all features for everyone; defaults to "free".
# When Stripe is configured below, per-user subscriptions take precedence.
PLAN=free

# ── Upload rate limiting ──────────────────────────────────────────────────────
# UPLOAD_RATE_MAX=10
# UPLOAD_RATE_WINDOW=15

# ── Stripe (billing) ─────────────────────────────────────────────────────────
# Get these from your Stripe Dashboard → Developers.
#
# STRIPE_SECRET_KEY      — Secret key (starts with sk_test_ or sk_live_)
# STRIPE_WEBHOOK_SECRET  — Webhook signing secret (starts with whsec_)
#                          Create the webhook endpoint in Stripe Dashboard and
#                          point it at https://your-domain/api/billing/webhook
#                          subscribing to:
#                            customer.subscription.created
#                            customer.subscription.updated
#                            customer.subscription.deleted
# STRIPE_PRO_PRICE_ID   — Price ID for the Pro monthly plan (starts with
#                          price_).  Create a Product → add a recurring price.
# APP_URL               — Your app's public URL (used for checkout return URLs)
#                          e.g. https://app.example.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
APP_URL=http://localhost:3000

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these values from your Supabase project → Settings → API.
#
# SUPABASE_URL         — Project URL (e.g. https://xyzcompany.supabase.co)
# SUPABASE_ANON_KEY    — Public anon key (safe for client-side; embedded in
#                        the frontend so the browser can call Supabase auth
#                        directly).
# SUPABASE_SERVICE_KEY — Service role key (SECRET — server-side only, bypasses
#                        RLS).  Never expose this in client-side code.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── AI Helpers (optional — Pro feature) ───────────────────────────────────────
# Powers the AI Draft Helpers panel (expedite email, escalation summary,
# meeting talking points).  Leave OPENAI_API_KEY blank to disable.
#
# OPENAI_API_KEY  — OpenAI API key (starts with sk-)
# AI_MODEL        — Chat model to use (default: gpt-4o-mini)
# AI_BASE_URL     — API base URL; change for Azure OpenAI or compatible proxies
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_BASE_URL=https://api.openai.com/v1

# ── Support email (SendGrid SMTP) ─────────────────────────────────────────────
# Used by POST /api/support to deliver contact form messages.
# Create a SendGrid account, verify your sender domain, and generate an API key
# with Mail Send permission.
#
# SUPPORT_SMTP_HOST  — smtp.sendgrid.net
# SUPPORT_SMTP_PORT  — 587 (TLS) or 465 (SSL)
# SUPPORT_SMTP_USER  — always the literal string: apikey
# SUPPORT_SMTP_PASS  — your SendGrid API key (starts with SG.)
# SUPPORT_EMAIL_FROM — verified sender address, e.g. support@yourdomain.com
SUPPORT_SMTP_HOST=smtp.sendgrid.net
SUPPORT_SMTP_PORT=587
SUPPORT_SMTP_USER=apikey
SUPPORT_SMTP_PASS=your_sendgrid_api_key_here
SUPPORT_EMAIL_FROM=support@yourdomain.com
